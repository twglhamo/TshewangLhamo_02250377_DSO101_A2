{
  "name": "todo-list-app",
  "version": "1.0.0",
  "description": "A Node.js to-do list application",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage --detectOpenHandles",
    "test:junit": "jest --coverage --reporters=default --reporters=jest-junit",
    "build": "npm run test",
    "start": "node index.js",
    "dev": "node --watch index.js"
  },
  "keywords": [
    "todo",
    "list",
    "task"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "junitReporterOptions": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathAsClassName": true
  }
}
